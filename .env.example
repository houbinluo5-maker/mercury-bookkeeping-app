# Keep ADMIN_PASSWORD server-only. The app still uses MVP password auth,
# not Supabase Auth.
ADMIN_PASSWORD=

# Server-only Supabase database access. Do not expose the service role key
# to browser code or NEXT_PUBLIC variables.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional team invitation email delivery through Resend.
# If these are empty, invitations are still created and the Team page
# keeps the manual copy-link fallback.
RESEND_API_KEY=
INVITE_EMAIL_FROM=

# Future integrations. Do not add live credentials to git.
MERCURY_CLIENT_ID=
MERCURY_CLIENT_SECRET=
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
META_APP_ID=
META_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
